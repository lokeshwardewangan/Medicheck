# Server-side Gemini API key. Used by all /api/* AI routes.
# NEVER prefix with NEXT_PUBLIC_ — it must not ship to the browser.
# Put the real value in .env.local (gitignored), NOT here.
GEMINI_API_KEY=

# Postgres connection string.
# Local dev (with `docker compose up -d`):
#   postgres://healthmate:healthmate@localhost:5432/healthmate
# Production: paste your Neon connection string here.
DATABASE_URL=

# Better-Auth session signing secret.
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Public URL where the app is served. Used for magic-link callback URLs.
BETTER_AUTH_URL=http://localhost:3000

# Resend (email delivery for magic links).
# Sign up at https://resend.com — 3,000 emails/month on free tier.
RESEND_API_KEY=
# Sender address. `onboarding@resend.dev` works without domain verification (for testing).
# For production, verify your own domain and use it here.
RESEND_FROM_EMAIL=onboarding@resend.dev

# Optional: explicit app base URL for the browser auth client.
# Defaults to window.location.origin if unset.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Sentry DSN for error tracking. App boots and runs fine without it.
# Get one from https://sentry.io after creating a project.
NEXT_PUBLIC_SENTRY_DSN=
