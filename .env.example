# Server-side Gemini API key. Used by all /api/* AI routes.
# NEVER prefix with NEXT_PUBLIC_ — it must not ship to the browser.
GEMINI_API_KEY=

# Postgres connection string.
# Local dev (with `docker compose up -d`):
#   postgres://medicheck:medicheck@localhost:5432/medicheck
# Production: paste your Neon connection string here.
DATABASE_URL=
